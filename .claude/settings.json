{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Loom v0.2 enforcement runtime. See adr/0011-claude-code-enforcement-runtime.md. Hooks emit Rule-22 (mechanical subset) records to memory/event-log/YYYY-MM-DD.jsonl. The introspective subset is emitted by the model itself per the 'Claim convention' in CLAUDE.md. Project-level (committed); user-local overrides go in settings.local.json (gitignored).",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/session-start.mjs"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/user-prompt-submit.mjs"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/pre-tool-use.mjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/post-tool-use.mjs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/stop.mjs"
          }
        ]
      }
    ]
  },
  "_generated_mcp": "regenerated from tools/mcp-servers/config.yaml — do not hand-edit the mcpServers block",
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ]
    },
    "git": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-git",
        "--repository",
        "."
      ]
    },
    "web-search": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ],
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      }
    }
  }
}
