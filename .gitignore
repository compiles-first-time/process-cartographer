# Secrets — never commit
.env
.env.*
!.env.example
*.pem
*.key
/secrets/
credentials.json

# Loom memory artifacts (rebuildable from source)
memory/vector-index/*
!memory/vector-index/.gitkeep
memory/knowledge-graph/*
!memory/knowledge-graph/.gitkeep
memory/event-log/*.jsonl
memory/event-log/*.log
memory/event-log/archive/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Build artifacts
dist/
build/
out/
*.egg-info/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Observability local data
observability/langfuse-data/
observability/prometheus-data/
observability/grafana-data/

# Local model artifacts
models/
*.gguf
*.safetensors

# Coverage / test artifacts
coverage/
.nyc_output/
*.lcov

# B2 oracle harness — downloaded pinned-SHA corpus (rebuildable; results ARE committed)
oracle/.cache/

