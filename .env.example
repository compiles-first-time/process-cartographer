# Loom environment variables — copy to .env and fill in
# Never commit .env

# Primary LLM provider
ANTHROPIC_API_KEY=

# Fallback providers (optional)
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Web search (Brave is the default MCP server)
BRAVE_API_KEY=

# GitHub (for the github MCP server)
GITHUB_PERSONAL_ACCESS_TOKEN=

# Langfuse (self-hosted by default)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Chat gateway (only one is needed, depending on choice at bootstrap)
TELEGRAM_BOT_TOKEN=
SLACK_BOT_TOKEN=
SIGNAL_API_URL=

# Database (if you provision one)
DATABASE_URL=

# LiteLLM proxy — Loom's LLM router (start: scripts/router.ps1 or scripts/router.sh)
# Exposes loom-haiku / loom-sonnet / loom-opus at http://localhost:4000
LITELLM_MASTER_KEY=sk-loom-dev    # change to a secret value in production
LITELLM_PORT=4000
