{
  "name": "process-cartographer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "A web app that ingests a UiPath REFramework automation (XAML) and renders a 3D city map of the process.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:loom": "node scripts/test.mjs",
    "test:raw": "node --test",
    "typecheck": "tsc --noEmit",
    "gen:schema": "node src/ir/genSchema.ts"
  },
  "dependencies": {
    "@react-three/drei": "^9.114.0",
    "@react-three/fiber": "^8.17.10",
    "exceljs": "^4.4.0",
    "fast-xml-parser": "^4.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.9",
    "vitest": "^2.1.3",
    "zod-to-json-schema": "^3.23.5"
  }
}
